# Frontend environment variables (Vite)
# Copy to .env.local and fill in values.
# Never commit real keys or secrets.

# Canonical public origin (used in SEO, sitemap, og-preview, SaveContactButton)
VITE_PUBLIC_ORIGIN=https://cardigo.co.il

# Backend API base (proxied via Netlify in production)
VITE_API_BASE_URL=http://localhost:5000/api

# Google Maps Embed API key (browser key, restrict HTTP referrers to cardigo.co.il and localhost)
# Required for Google Maps iframe in premium LocationSection.
# If absent, iframe is hidden and nav buttons still render.
# Enable "Maps Embed API" in Google Cloud Console before use.
VITE_GOOGLE_MAPS_EMBED_API_KEY=

# Optional: guide video embed URLs (YouTube embed format only)
VITE_GUIDE_URL_MOBILE=
VITE_GUIDE_URL_DESKTOP=

# Optional: enable SEO debug overlay
VITE_SEO_DEBUG=
