{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "npm run build:client && npm run build:ssr && npm run build:ssr-card && npm run generate:ssg && npm run check:ssg-output",
        "build:client": "vite build",
        "build:ssr": "vite build --ssr src/entry-server.jsx && node scripts/write-ssr-package-type.mjs",
        "build:ssr-card": "vite build --ssr src/entry-server-card.jsx --outDir dist_ssr_card && node scripts/write-ssr-card-package-type.mjs",
        "generate:ssg": "node scripts/generate-static.mjs",
        "check:ssg-output": "node scripts/check-ssg-output.mjs",
        "lint": "eslint .",
        "preview": "vite preview",
        "check:inline-styles": "node scripts/check-no-inline-styles.mjs",
        "check:skins": "node scripts/check-skins-token-only.mjs",
        "check:contract": "node scripts/check-template-contract.mjs",
        "check:site-actions": "node scripts/check-site-actions-ssot.mjs",
        "check:typography": "node scripts/check-typography-policy.mjs",
        "check:typography:boundary": "node scripts/check-typography-card-boundary.mjs",
        "check:seo-static-shell": "node scripts/check-seo-static-shell.mjs"
    },
    "dependencies": {
        "axios": "^1.13.2",
        "qrcode.react": "^4.2.0",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "react-easy-crop": "^5.0.8",
        "react-helmet-async": "^2.0.5",
        "react-router-dom": "^7.10.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/react": "18.2.79",
        "@types/react-dom": "18.2.25",
        "@vitejs/plugin-react": "^5.1.1",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "vite": "^7.2.4"
    }
}
